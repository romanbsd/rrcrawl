# auto uses OneCLI when ONECLI_URL is present, otherwise provider API keys.
RRCRAWL_AUTH_MODE=auto

# Optional comma-separated provider allowlist.
# In env mode the default is every provider with a configured key.
# In onecli mode the default is all providers.
RRCRAWL_PROVIDERS=firecrawl,tavily,scrapedo

FIRECRAWL_API_KEY=
TAVILY_API_KEY=
SCRAPEDO_API_TOKEN=

# Optional operational tuning.
RRCRAWL_REQUEST_TIMEOUT_MS=60000
RRCRAWL_CRAWL_TIMEOUT_MS=180000
RRCRAWL_POLL_INTERVAL_MS=2000

# Optional API endpoint overrides.
FIRECRAWL_API_URL=https://api.firecrawl.dev
TAVILY_API_URL=https://api.tavily.com
SCRAPEDO_API_URL=https://api.scrape.do/
