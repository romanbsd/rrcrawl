{
  "name": "rrcrawl",
  "version": "0.1.0",
  "description": "Tiny round-robin crawl MCP backed by Firecrawl, Tavily, and Scrape.do",
  "license": "MIT",
  "type": "module",
  "bin": {
    "rrcrawl": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "prepack": "npm run build",
    "prepublishOnly": "npm test && npm run check"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "dotenv": "^17.2.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "overrides": {
    "@hono/node-server": "2.0.11"
  },
  "publishConfig": {
    "access": "public"
  }
}
